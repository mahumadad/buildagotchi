// Typechecks the tests, which `tsconfig.json` cannot: its `rootDir` is `src`,
// and widening `include` would drag `test/` into `dist/`. Same strictness, no
// emit (D-11).
//
// Without this, vitest transpiles the tests without checking them. That is how
// five calls to `resolve()` kept compiling after it gained a required third
// argument, silently passing `undefined`, with the whole suite green.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "..",
    // DOM only here: the bridge runs on Node, but the emulator's JS is browser
    // code and its jsdom tests touch `document` (D-14).
    "lib": ["ES2023", "DOM"],
    "allowJs": true,
    "types": ["node", "vitest/globals"]
  },
  // Only `breath.ts`: `led-pulse.ts` imports Moddable's `neostrand`, which does
  // not resolve under Node. The Moddable toolchain typechecks that file; we
  // typecheck the arithmetic (D-03).
  "include": ["src", "test", "../firmware/mods/breath.ts"]
}
