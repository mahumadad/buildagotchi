{
  "name": "buildagotchi-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "bridge": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts --simulate",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "format": "biome format --write src test"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "pino": "^9.6.0",
    "uuid": "^11.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "@biomejs/biome@1.9.4": true,
    "esbuild@0.28.1": true
  }
}
